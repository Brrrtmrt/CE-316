<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iae.gui.controllers.MainController">
   
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu text="File">
            <items>
              <MenuItem text="Save" />
              <MenuItem text="Load" />
              <SeparatorMenuItem />
              <MenuItem text="Exit" />
            </items>
          </Menu>
          <Menu text="Help">
            <items>
              <MenuItem text="User Manual" />
            </items>
          </Menu>
          <Menu text="DarkMode" />
          <Menu text="Exit" />
        </menus>
      </MenuBar>
   </top>

   <left>
      <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #eeeeee; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <children>
            <Button fx:id="btnCreateAssessment" maxWidth="1.7976931348623157E308" prefHeight="80.0" text="Create New Assessment" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px;" />
            <Button fx:id="btnConfigSettings" maxWidth="1.7976931348623157E308" prefHeight="80.0" text="Configuration Settings" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px;" />
            <Button fx:id="btnProjectResults" maxWidth="1.7976931348623157E308" prefHeight="80.0" text="Project Results" textAlignment="CENTER" wrapText="true" style="-fx-font-size: 14px;" />
         </children>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" BorderPane.alignment="CENTER">
         <children>
            <Label text="Lütfen soldan bir işlem seçiniz." textFill="#999999" />
         </children>
      </StackPane>
   </center>

</BorderPane>