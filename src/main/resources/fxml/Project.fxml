<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.iae.gui.controllers.ProjectController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <Label text="Project Management" textFill="#333333">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>
    <Label text="Create a new evaluation project or open an existing one." textFill="#666666" />

    <Separator prefWidth="200.0" />

    <GridPane hgap="15.0" vgap="20.0">
        <columnConstraints>
            <ColumnConstraints halignment="LEFT" minWidth="150.0" prefWidth="220.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="60.0" prefHeight="80.0" vgrow="SOMETIMES" /> </rowConstraints>

        <children>
            <Label text="Project Name:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <font><Font size="14.0" /></font>
            </Label>
            <TextField fx:id="txtProjectName" promptText="e.g. CE316_Midterm" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Submissions Directory (ZIPs):" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <font><Font size="14.0" /></font>
            </Label>
            <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <children>
                    <TextField fx:id="txtDirectoryPath" promptText="Select folder containing student ZIPs..." HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnBrowse" mnemonicParsing="false" text="Browse..." />
                </children>
            </HBox>

            <Label text="Select Configuration:" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <font><Font size="14.0" /></font>
            </Label>
            <ComboBox fx:id="cmbConfigurations" prefWidth="300.0" promptText="Select a language configuration..." GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Program Arguments:" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <font><Font size="14.0" /></font>
            </Label>
            <TextField fx:id="txtArguments" promptText="e.g. input.txt 5 (Leave blank if none)" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Expected Output:" GridPane.columnIndex="0" GridPane.rowIndex="4">
                <font><Font size="14.0" /></font>
            </Label>
            <TextArea fx:id="txtExpectedOutput" promptText="Enter the exact expected output here..." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        </children>
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="15.0">
        <children>
            <Label fx:id="lblStatus" text="" textFill="GREEN" visible="false" />
            <Button fx:id="btnOpenProject" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #f0f0f0; -fx-text-fill: #333333; -fx-font-weight: bold; -fx-font-size: 14px; -fx-border-color: #cccccc; -fx-border-radius: 3px;" text="Open Existing" />
            <Button fx:id="btnCreateProject" mnemonicParsing="false" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #3266ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Create Project" />
            <Button fx:id="btnRunEvaluation" mnemonicParsing="false" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" text="Run &amp; Evaluate" disable="true" />
        </children>
    </HBox>
</VBox>